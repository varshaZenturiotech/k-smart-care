# K-SMART CARE Backend Environment Configuration
# Copy this file to .env and configure the values for your environment.

# Server Settings
PORT=5000
NODE_ENV=production

# Database Settings
# For Docker deployments, use mongodb://mongodb:27017/ksmart_care
MONGO_URI=mongodb://localhost:27017/ksmart_care

# JWT Authentication
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=8h

# AI / LLM Configurations
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
VLLM_URL=
OLLAMA_URL=

# Vector Database (ChromaDB) Settings
# For Docker deployments, use http://chromadb:8000
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=ksmart_circulars
EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# CORS Configurations
# Set this to the frontend origin (or Nginx reverse proxy URL)
CLIENT_ORIGIN=http://localhost:5173

